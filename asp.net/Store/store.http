@Api_HostAddress = http://localhost:5107

### Products - Get all
GET {{Api_HostAddress}}/api/Product
Accept: application/json

### Products - Get by id
GET {{Api_HostAddress}}/api/Product/1
Accept: application/json

### Categories - Get all
GET {{Api_HostAddress}}/api/Category
Accept: application/json

### Categories - Get by id
GET {{Api_HostAddress}}/api/Category/1
Accept: application/json

### Categories - Create valid
POST {{Api_HostAddress}}/api/Category
Content-Type: application/json

{
	"name": "Deelectics"
}

### Categories - Create duplicate (expects 409)
POST {{Api_HostAddress}}/api/Category
Content-Type: application/json

{
	"name": "electronics"
}

### Categories - Update valid
PUT {{Api_HostAddress}}/api/Category/1
Content-Type: application/json

{
	"name": "Electronics and Gadgets"
}

### Categories - Delete missing (expects 404)
DELETE {{Api_HostAddress}}/api/Category/999

### Categories - Create invalid (expects 400)
POST {{Api_HostAddress}}/api/Category
Content-Type: application/json

{
	"name": "   "
}

### Orders - Get all
GET {{Api_HostAddress}}/api/Order
Accept: application/json

### Orders - Get by id
GET {{Api_HostAddress}}/api/Order/1
Accept: application/json

### Products - Create valid (requires existing category id)
POST {{Api_HostAddress}}/api/Product
Content-Type: application/json

{
	"name": "Laptop",
	"price": 1200.499,
	"categoryId": 1
}

### Products - Create with unknown category (expects 404)
POST {{Api_HostAddress}}/api/Product
Content-Type: application/json

{
	"name": "Phone",
	"price": 500,
	"categoryId": 999
}

### Products - Update valid
PUT {{Api_HostAddress}}/api/Product/1
Content-Type: application/json

{
	"name": "Laptop Pro",
	"price": 1500,
	"categoryId": 1
}

### Products - Delete missing (expects 404)
DELETE {{Api_HostAddress}}/api/Product/999

### Orders - Create valid (requires existing product id)
POST {{Api_HostAddress}}/api/Order
Content-Type: application/json

{
	"productId": 1,
	"quantity": 2
}

### Orders - Create with invalid quantity (expects 400)
POST {{Api_HostAddress}}/api/Order
Content-Type: application/json

{
	"productId": 1,
	"quantity": 0
}

### Orders - Create with unknown product (expects 404)
POST {{Api_HostAddress}}/api/Order
Content-Type: application/json

{
	"productId": 999,
	"quantity": 3
}

### Orders - Update valid
PUT {{Api_HostAddress}}/api/Order/1
Content-Type: application/json

{
	"productId": 1,
	"quantity": 5
}

### Orders - Delete missing (expects 404)
DELETE {{Api_HostAddress}}/api/Order/999
